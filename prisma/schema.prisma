generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(USER)
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  vehicles     Vehicle[]
  permits      Permit[]
  reservations Reservation[]
}

enum Role {
  ADMIN
  MANAGER
  USER
}

model Vehicle {
  id           String        @id @default(cuid())
  plateNumber  String        @unique
  brand        String
  model        String
  color        String
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  createdAt    DateTime      @default(now())
  permits      Permit[]
  reservations Reservation[]
  accessLogs   AccessLog[]
}

model ParkingZone {
  id          String        @id @default(cuid())
  name        String
  description String?
  totalSlots  Int
  floor       String?
  type        ZoneType      @default(REGULAR)
  slots       ParkingSlot[]
}

enum ZoneType {
  REGULAR
  VIP
  DISABLED
  LARGE
}

model ParkingSlot {
  id           String        @id @default(cuid())
  slotNumber   String
  zoneId       String
  zone         ParkingZone   @relation(fields: [zoneId], references: [id])
  status       SlotStatus    @default(AVAILABLE)
  reservations Reservation[]
  accessLogs   AccessLog[]

  @@unique([slotNumber, zoneId])
}

enum SlotStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

model Permit {
  id          String       @id @default(cuid())
  permitNumber String      @unique @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  vehicleId   String
  vehicle     Vehicle      @relation(fields: [vehicleId], references: [id])
  type        PermitType
  status      PermitStatus @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime
  zoneAccess  String?
  price       Float
  createdAt   DateTime     @default(now())
  payments    Payment[]
}

enum PermitType {
  DAILY
  MONTHLY
  YEARLY
  VISITOR
}

enum PermitStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

model Reservation {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  vehicleId   String
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id])
  slotId      String
  slot        ParkingSlot       @relation(fields: [slotId], references: [id])
  startTime   DateTime
  endTime     DateTime
  status      ReservationStatus @default(PENDING)
  totalPrice  Float
  createdAt   DateTime          @default(now())
  payments    Payment[]
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  permitId      String?
  permit        Permit?       @relation(fields: [permitId], references: [id])
  reservationId String?
  reservation   Reservation?  @relation(fields: [reservationId], references: [id])
  createdAt     DateTime      @default(now())
}

enum PaymentMethod {
  CARD
  CASH
  TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model AccessLog {
  id        String    @id @default(cuid())
  vehicleId String
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  slotId    String?
  slot      ParkingSlot? @relation(fields: [slotId], references: [id])
  entryTime DateTime  @default(now())
  exitTime  DateTime?
  method    String    @default("MANUAL")
}
